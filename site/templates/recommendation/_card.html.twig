{# Carte de recommandation : présente une formation à découvrir (niveau, durée,
   description courte, tags). À distinguer de la carte du dashboard, qui montre
   la progression. `formation` = Formation. `enrolled` (optionnel) = l'utilisateur
   suit déjà cette formation, on l'indique par un badge. #}
{% set enrolled = enrolled|default(false) %}
<a href="{{ path('app_formation_show', { slug: formation.slug }) }}"
   class="card card--interactive no-underline flex flex-col gap-3">
    <div class="flex items-center gap-2 flex-wrap text-xs text-muted">
        {% if formation.difficulty %}
            <span class="badge badge--neutral">{{ formation.difficulty.label }}</span>
        {% endif %}
        {% if formation.estimatedMinutes %}
            <span>{{ formation.estimatedMinutes }} min</span>
        {% endif %}
        {% if enrolled %}
            <span class="badge badge--accent">Suivie</span>
        {% endif %}
        <span class="ml-auto">{{ formation.chapters|length }} chapitre{{ formation.chapters|length > 1 ? 's' : '' }}</span>
    </div>
    <div>
        <h3 class="text-md font-semibold tracking-tight text-fg mb-1">{{ formation.title }}</h3>
        <p class="text-sm text-fg-secondary line-clamp-2">{{ formation.description|striptags }}</p>
    </div>
    {% if formation.tags is not empty %}
        <div class="flex flex-wrap gap-1.5 mt-auto pt-1">
            {% for tag in formation.tags %}
                <span class="tag"><span class="tag__dot"></span>{{ tag.label }}</span>
            {% endfor %}
        </div>
    {% endif %}
</a>
