<!DOCTYPE html>
<html lang="fr" data-theme="light">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Formations{% endblock %}</title>
        <link rel="icon" href="/logo.png" type="image/png">
        {# Pose le thème avant le rendu pour éviter le flash clair au chargement.
           Préférence sauvegardée, sinon réglage système. Le contrôleur Stimulus
           « theme » prend le relais pour la bascule au clic. #}
        <script>
            (function () {
                try {
                    var stored = localStorage.getItem('theme');
                    var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
                    document.documentElement.dataset.theme = theme;
                } catch (e) {}
            })();
        </script>
        {# Polices du design system : IBM Plex Sans + IBM Plex Mono #}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body class="min-h-screen flex flex-col">
        {# Liens de navigation : source unique, bouclée pour le bureau et le mobile.
           `active` met en valeur l'entrée correspondant à la route courante. #}
        {% set currentRoute = app.request.attributes.get('_route') %}
        {% set navItems = [
            { route: 'app_formation_index', label: 'Catalogue', show: true, active: currentRoute starts with 'app_formation' },
            { route: 'app_dashboard', label: 'Mes formations', show: app.user is not null, active: currentRoute starts with 'app_dashboard' },
            { route: 'app_recommendations', label: 'Recommandations', show: true, active: currentRoute starts with 'app_recommendation' },
            { route: 'app_admin_formations', label: 'Admin', show: is_granted('ROLE_ADMIN'), active: currentRoute starts with 'app_admin' },
        ] %}
        <header data-controller="menu" class="border-b border-line bg-surface">
            <div class="container-page h-16 flex items-center gap-4 sm:gap-6">
                <a href="{{ path('app_home') }}" class="flex items-center gap-2 no-underline focus-ring shrink-0">
                    <img src="/logo.png" class="inline-block size-[18px]"></img>
                    <span class="font-mono text-md font-semibold text-fg tracking-tight">formations</span>
                </a>

                {# Navigation bureau (md+). #}
                <nav class="hidden md:flex items-center gap-4 lg:gap-5 text-sm">
                    {% for item in navItems|filter(item => item.show) %}
                        <a href="{{ path(item.route) }}" class="no-underline {{ item.active ? 'text-fg font-medium' : 'text-fg-secondary hover:text-fg' }}">{{ item.label }}</a>
                    {% endfor %}
                </nav>

                <div class="ml-auto flex items-center gap-2 sm:gap-3 shrink-0">
                    <button
                        type="button"
                        data-controller="theme"
                        data-action="theme#toggle"
                        class="inline-flex items-center justify-center size-9 rounded-md text-fg-secondary hover:text-fg hover:bg-surface-2 focus-ring transition-colors"
                        aria-label="Changer de thème"
                        title="Changer de thème"
                    >
                        {# Lune : visible en thème clair, bascule vers sombre. #}
                        <svg data-theme-target="toDark" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
                        </svg>
                        {# Soleil : visible en thème sombre, bascule vers clair. #}
                        <svg data-theme-target="toLight" class="hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="12" cy="12" r="4"></circle>
                            <path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41m11.32-11.32 1.41-1.41"></path>
                        </svg>
                    </button>

                    {# Authentification bureau (md+). #}
                    <div class="hidden md:flex items-center gap-3">
                        {% if app.user %}
                            <a href="{{ path('app_profile') }}" class="text-sm text-fg-secondary no-underline font-medium hover:text-fg">{{ app.user.displayName ?: app.user.userIdentifier }}</a>
                            <a href="{{ path('app_logout') }}" class="text-sm text-fg-secondary no-underline font-medium hover:text-fg">Déconnexion</a>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="text-sm text-fg-secondary no-underline font-medium hover:text-fg">Connexion</a>
                            <a href="{{ path('app_register') }}" class="btn btn--primary focus-ring">Créer un compte</a>
                        {% endif %}
                    </div>

                    {# Burger (mobile uniquement). #}
                    <button
                        type="button"
                        data-menu-target="button"
                        data-action="menu#toggle"
                        class="md:hidden inline-flex items-center justify-center size-9 rounded-md text-fg-secondary hover:text-fg hover:bg-surface-2 focus-ring transition-colors"
                        aria-label="Ouvrir le menu"
                        aria-controls="mobile-menu"
                        aria-expanded="false"
                    >
                        <svg data-menu-target="open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M3 6h18M3 12h18M3 18h18"></path>
                        </svg>
                        <svg data-menu-target="close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M18 6 6 18M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
            </div>

            {# Panneau mobile déroulant, masqué par défaut et au-delà de md. #}
            <div id="mobile-menu" data-menu-target="panel" class="hidden md:hidden border-t border-line">
                <nav class="container-page py-3 flex flex-col gap-1 text-sm">
                    {% for item in navItems|filter(item => item.show) %}
                        <a href="{{ path(item.route) }}" class="block rounded-md px-3 py-2 no-underline {{ item.active ? 'text-fg font-medium bg-surface-2' : 'text-fg-secondary hover:text-fg hover:bg-surface-2' }}">{{ item.label }}</a>
                    {% endfor %}
                    <div class="my-2 border-t border-line"></div>
                    {% if app.user %}
                        <a href="{{ path('app_profile') }}" class="block rounded-md px-3 py-2 no-underline text-fg-secondary font-medium hover:text-fg hover:bg-surface-2">{{ app.user.displayName ?: app.user.userIdentifier }}</a>
                        <a href="{{ path('app_logout') }}" class="block rounded-md px-3 py-2 no-underline text-fg-secondary font-medium hover:text-fg hover:bg-surface-2">Déconnexion</a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="block rounded-md px-3 py-2 no-underline text-fg-secondary font-medium hover:text-fg hover:bg-surface-2">Connexion</a>
                        <a href="{{ path('app_register') }}" class="btn btn--primary focus-ring mt-1 mx-3">Créer un compte</a>
                    {% endif %}
                </nav>
            </div>
        </header>

        {% set flashes = app.flashes %}
        {% if flashes is not empty %}
            <div
                data-controller="toast"
                data-toast-max-value="3"
                class="fixed top-4 right-4 z-50 flex flex-col gap-2 w-[min(92vw,360px)]"
                aria-live="polite"
            >
                {% for label, messages in flashes %}
                    {% for message in messages %}
                        <button
                            type="button"
                            data-toast-target="item"
                            data-action="toast#dismiss"
                            class="toast {{ label == 'success' ? 'toast--success' : (label == 'error' ? 'toast--danger' : '') }}"
                        >
                            <span class="toast__msg">{{ message }}</span>
                            <span class="toast__close" aria-hidden="true">&times;</span>
                        </button>
                    {% endfor %}
                {% endfor %}
            </div>
        {% endif %}

        <main class="flex-1">
            {% block body %}{% endblock %}
        </main>

        <footer class="border-t border-line bg-surface">
            <div class="container-page py-6 flex items-center justify-between gap-4 flex-wrap">
                <span class="text-sm text-muted">Plateforme de formations</span>
                <span class="font-mono text-xs text-muted">Apprends · Suis · Progresse</span>
            </div>
        </footer>
    </body>
</html>
