<!DOCTYPE html>
<html lang="fr" data-theme="light">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Formations{% endblock %}</title>
        <link rel="icon" href="/logo.png" type="image/png">
        {# Polices du design system : IBM Plex Sans + IBM Plex Mono #}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body class="min-h-screen flex flex-col">
        <header class="border-b border-line bg-surface">
            <div class="container-page h-16 flex items-center gap-6">
                <a href="{{ path('app_home') }}" class="flex items-center gap-2 no-underline focus-ring">
                    <img src="/logo.png" class="inline-block size-[18px]"></img>
                    <span class="font-mono text-md font-semibold text-fg tracking-tight">formations</span>
                </a>
                <nav class="ml-4 flex items-center gap-5 text-sm">
                    {# Liens actives au fil des milestones (catalogue, dashboard, recos). #}
                    {% set isCatalogue = app.request.attributes.get('_route') starts with 'app_formation' %}
                    <a href="{{ path('app_formation_index') }}" class="no-underline {{ isCatalogue ? 'text-fg font-medium' : 'text-fg-secondary hover:text-fg' }}">Catalogue</a>
                    {% if app.user %}
                        <a href="{{ path('app_dashboard') }}" class="text-fg-secondary no-underline hover:text-fg">Mes formations</a>
                    {% endif %}
                    <a href="{{ path('app_recommendations') }}" class="text-fg-secondary no-underline hover:text-fg">Recommandations</a>
                </nav>
                <div class="ml-auto flex items-center gap-3">
                    {% if app.user %}
                        <a href="{{ path('app_profile') }}" class="text-sm text-fg-secondary no-underline font-medium hover:text-fg">{{ app.user.displayName ?: app.user.userIdentifier }}</a>
                        <a href="{{ path('app_logout') }}" class="text-sm text-fg-secondary no-underline font-medium hover:text-fg">Déconnexion</a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="text-sm text-fg-secondary no-underline font-medium hover:text-fg">Connexion</a>
                        <a href="{{ path('app_register') }}" class="btn btn--primary focus-ring">Créer un compte</a>
                    {% endif %}
                </div>
            </div>
        </header>

        {% set flashes = app.flashes %}
        {% if flashes is not empty %}
            <div
                data-controller="toast"
                data-toast-max-value="3"
                class="fixed top-4 right-4 z-50 flex flex-col gap-2 w-[min(92vw,360px)]"
                aria-live="polite"
            >
                {% for label, messages in flashes %}
                    {% for message in messages %}
                        <button
                            type="button"
                            data-toast-target="item"
                            data-action="toast#dismiss"
                            class="toast {{ label == 'success' ? 'toast--success' : (label == 'error' ? 'toast--danger' : '') }}"
                        >
                            <span class="toast__msg">{{ message }}</span>
                            <span class="toast__close" aria-hidden="true">&times;</span>
                        </button>
                    {% endfor %}
                {% endfor %}
            </div>
        {% endif %}

        <main class="flex-1">
            {% block body %}{% endblock %}
        </main>

        <footer class="border-t border-line bg-surface">
            <div class="container-page py-6 flex items-center justify-between gap-4 flex-wrap">
                <span class="text-sm text-muted">Plateforme de formations</span>
                <span class="font-mono text-xs text-muted">Apprends · Suis · Progresse</span>
            </div>
        </footer>
    </body>
</html>
