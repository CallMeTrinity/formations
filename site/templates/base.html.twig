<!DOCTYPE html>
<html lang="fr" data-theme="light">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Formations{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><rect width=%22128%22 height=%22128%22 rx=%2212%22 fill=%22%23d9622b%22/></svg>">

        {# Polices du design system : IBM Plex Sans + IBM Plex Mono #}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body class="min-h-screen flex flex-col">
        <header class="border-b border-line bg-surface">
            <div class="container-page h-16 flex items-center gap-6">
                <a href="{{ path('app_home') }}" class="flex items-center gap-2 no-underline focus-ring">
                    <span class="inline-block size-[18px] rounded-sm bg-accent"></span>
                    <span class="font-mono text-md font-semibold text-fg tracking-tight">formations</span>
                </a>
                <nav class="ml-4 flex items-center gap-5 text-sm">
                    {# Liens actives au fil des milestones (catalogue, dashboard, recos). #}
                    <a href="#" class="text-fg font-medium no-underline">Catalogue</a>
                    <a href="#" class="text-fg-secondary no-underline hover:text-fg">Mes formations</a>
                    <a href="#" class="text-fg-secondary no-underline hover:text-fg">Recommandations</a>
                </nav>
                <div class="ml-auto flex items-center gap-3">
                    {% if app.user %}
                        <span class="text-sm text-fg-secondary font-medium">{{ app.user.displayName ?? app.user.userIdentifier }}</span>
                        <a href="{{ path('app_logout') }}" class="text-sm text-fg-secondary no-underline font-medium hover:text-fg">Déconnexion</a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="text-sm text-fg-secondary no-underline font-medium hover:text-fg">Connexion</a>
                        <a href="{{ path('app_register') }}" class="btn btn--primary focus-ring">Créer un compte</a>
                    {% endif %}
                </div>
            </div>
        </header>

        <main class="flex-1">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="container-page mt-4">
                        <div class="callout {{ label == 'success' ? 'callout--success' : (label == 'error' ? 'callout--danger' : '') }}">
                            <div class="text-sm text-fg-secondary">{{ message }}</div>
                        </div>
                    </div>
                {% endfor %}
            {% endfor %}
            {% block body %}{% endblock %}
        </main>

        <footer class="border-t border-line bg-surface">
            <div class="container-page py-6 flex items-center justify-between gap-4 flex-wrap">
                <span class="text-sm text-muted">Plateforme de formations — contenu synchronisé depuis le dépôt markdown.</span>
                <span class="font-mono text-xs text-muted">Apprends · Suis · Progresse</span>
            </div>
        </footer>
    </body>
</html>
