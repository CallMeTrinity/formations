{% extends 'base.html.twig' %}

{% block title %}Formations — accueil{% endblock %}

{% block body %}
<section class="mx-auto max-w-6xl px-4 py-16">
    <h1 class="text-4xl font-bold text-ink">Apprends, suis ta progression, progresse.</h1>
    <p class="mt-4 max-w-2xl text-lg text-muted">
        Une plateforme pour consulter les formations, suivre ton avancement chapitre par chapitre
        et recevoir des recommandations adaptees a tes preferences.
    </p>
    <div class="mt-8 flex gap-4">
        <a href="#" class="rounded-md bg-brand-600 px-5 py-2.5 text-white font-medium hover:bg-brand-700">Explorer le catalogue</a>
        <a href="#" class="rounded-md border border-line bg-surface px-5 py-2.5 font-medium hover:bg-canvas">Creer un compte</a>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-3">
        <div class="rounded-card border border-line bg-surface p-6">
            <h2 class="font-semibold text-ink">Consulter</h2>
            <p class="mt-2 text-sm text-muted">Des formations structurees en chapitres, lisibles directement dans le navigateur.</p>
        </div>
        <div class="rounded-card border border-line bg-surface p-6">
            <h2 class="font-semibold text-ink">Suivre</h2>
            <p class="mt-2 text-sm text-muted">Marque les chapitres termines et visualise ta progression.</p>
        </div>
        <div class="rounded-card border border-line bg-surface p-6">
            <h2 class="font-semibold text-ink">Recommander</h2>
            <p class="mt-2 text-sm text-muted">Des suggestions basees sur tes preferences et ton niveau.</p>
        </div>
    </div>
</section>
{% endblock %}
