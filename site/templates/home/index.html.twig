{% extends 'base.html.twig' %}

{% block title %}Formations — accueil{% endblock %}

{% block body %}
<section class="border-b border-line">
    <div class="container-page py-12 sm:py-20 grid gap-10 lg:gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
        <div>
            <p class="eyebrow mb-4">Formations pour développeurs · pratique d'abord</p>
            <h1 class="text-4xl font-bold tracking-tight leading-tight text-fg mb-5 max-w-[16ch]">
                Apprends, suis ta progression, progresse.
            </h1>
            <p class="text-md text-fg-secondary max-w-[52ch] mb-6">
                Une plateforme pour consulter les formations du dépôt, suivre ton avancement chapitre
                par chapitre et recevoir des recommandations adaptées à tes préférences et à ton niveau.
            </p>
            <div class="flex flex-wrap items-center gap-3">
                <a href="{{ path('app_formation_index') }}" class="btn btn--primary btn--lg focus-ring">Explorer le catalogue</a>
                {% if not app.user %}
                    <a href="{{ path('app_register') }}" class="btn btn--secondary btn--lg focus-ring">Créer un compte</a>
                {% else %}
                    <a href="{{ path('app_dashboard') }}" class="btn btn--secondary btn--lg focus-ring">Mes formations</a>
                {% endif %}
            </div>
            <p class="text-sm text-muted mt-5">Les formations publiques se lisent sans compte. Un compte gratuit débloque la suite.</p>
        </div>

        <div class="bg-surface-inset border border-line rounded-md overflow-hidden shadow-[var(--shadow-md)]">
            <div class="flex items-center gap-2 p-3 border-b border-line">
                <span class="size-[9px] rounded-full bg-danger"></span>
                <span class="size-[9px] rounded-full bg-warning"></span>
                <span class="size-[9px] rounded-full bg-success"></span>
                <span class="font-mono text-xs text-muted ml-2">~/formations</span>
            </div>
            <pre class="m-0 p-6 font-mono text-sm leading-relaxed text-fg-secondary overflow-x-auto"><span class="text-accent">$</span> formations suivre symfony
<span class="text-muted">→ chapitre 03 — le routing</span>

  <span class="text-fg">routes</span>     définir une route
  <span class="text-fg">controller</span> renvoyer une réponse
  <span class="text-fg">.</span>          marquer le chapitre terminé

<span class="text-success">✓ progression 7/12 chapitres</span></pre>
        </div>
    </div>
</section>

{% if recommendations is not empty %}
<section class="border-b border-line bg-surface-inset">
    <div class="container-page py-16">
        <div class="flex items-end justify-between gap-4 flex-wrap mb-6">
            <div>
                <p class="eyebrow mb-3">{{ personalized ? 'Recommandé pour toi' : 'À découvrir' }}</p>
                <h2 class="text-2xl font-bold tracking-tight text-fg">
                    {{ personalized ? 'Des formations choisies selon tes préférences' : 'Les formations populaires du moment' }}
                </h2>
                {% if not personalized and app.user %}
                    <p class="text-sm text-muted mt-2">
                        <a href="{{ path('app_preferences') }}" class="link-accent">Renseigne tes préférences</a>
                        pour des suggestions adaptées à tes tags et ton niveau.
                    </p>
                {% endif %}
            </div>
            <a href="{{ path('app_recommendations') }}" class="btn btn--secondary focus-ring shrink-0">Voir tout</a>
        </div>
        {{ include('recommendation/_list.html.twig', { recommendations: recommendations }) }}
    </div>
</section>
{% endif %}

<section class="border-b border-line">
    <div class="container-page py-16">
        <p class="eyebrow mb-3">Avec ou sans compte</p>
        <h2 class="text-2xl font-bold tracking-tight text-fg mb-2">Lis librement, connecte-toi pour la suite</h2>
        <p class="text-md text-fg-secondary max-w-[60ch] mb-8">
            Pas de barrière pour commencer. Le compte sert à débloquer le contenu en préparation et à
            garder une trace de ton avancement.
        </p>
        <div data-controller="reveal" class="grid gap-5 md:grid-cols-2">
            <div class="card">
                <span class="badge badge--neutral mb-4">SANS COMPTE</span>
                <h3 class="text-lg font-semibold tracking-tight text-fg mb-3">Consulter le catalogue public</h3>
                <ul class="flex flex-col gap-2 text-sm text-fg-secondary">
                    <li class="flex gap-2"><span class="text-accent">→</span> Lire les formations publiques, chapitre par chapitre.</li>
                    <li class="flex gap-2"><span class="text-accent">→</span> Filtrer et chercher dans le catalogue.</li>
                    <li class="flex gap-2"><span class="text-accent">→</span> Aucune inscription, rien à installer.</li>
                </ul>
            </div>
            <div class="card border-line-strong">
                <span class="badge badge--accent mb-4">COMPTE GRATUIT</span>
                <h3 class="text-lg font-semibold tracking-tight text-fg mb-3">Débloquer et suivre</h3>
                <ul class="flex flex-col gap-2 text-sm text-fg-secondary">
                    <li class="flex gap-2"><span class="text-accent">→</span> Accéder aux formations en <strong class="text-fg font-medium">beta</strong>, encore en rodage.</li>
                    <li class="flex gap-2"><span class="text-accent">→</span> Sauvegarder ta progression d'un appareil à l'autre.</li>
                    <li class="flex gap-2"><span class="text-accent">→</span> Recevoir des recommandations selon tes tags et ton niveau.</li>
                </ul>
                {% if not app.user %}
                    <div class="mt-5 flex flex-wrap items-center gap-3">
                        <a href="{{ path('app_register') }}" class="btn btn--primary focus-ring">Créer un compte</a>
                        <a href="{{ path('app_login') }}" class="link-accent text-sm">J'ai déjà un compte</a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</section>

<section>
    <div class="container-page py-16">
        <p class="eyebrow mb-3">Comment ça marche</p>
        <h2 class="text-2xl font-bold tracking-tight text-fg mb-6">Trois usages, un seul endroit</h2>
        <div data-controller="reveal" class="grid gap-5 sm:grid-cols-3">
            <div class="card card--interactive">
                <span class="badge badge--accent mb-4">CONSULTER</span>
                <h3 class="text-lg font-semibold tracking-tight text-fg mb-2">Lire les formations</h3>
                <p class="text-sm text-fg-secondary">Des formations structurées en chapitres, lisibles directement dans le navigateur.</p>
            </div>
            <div class="card card--interactive">
                <span class="badge badge--accent mb-4">SUIVRE</span>
                <h3 class="text-lg font-semibold tracking-tight text-fg mb-2">Mesurer ta progression</h3>
                <p class="text-sm text-fg-secondary mb-4">Marque les chapitres terminés et visualise ton avancement.</p>
                <div data-controller="progress" class="progress"><div class="progress__bar" style="width:58%"></div></div>
            </div>
            <div class="card card--interactive">
                <span class="badge badge--accent mb-4">RECOMMANDER</span>
                <h3 class="text-lg font-semibold tracking-tight text-fg mb-2">Trouver la suite</h3>
                <p class="text-sm text-fg-secondary">Des suggestions basées sur tes préférences, tes tags favoris et ton niveau.</p>
            </div>
        </div>
    </div>
</section>
{% endblock %}
