{% extends 'base.html.twig' %}

{% block title %}{{ formation.title }} — Formations{% endblock %}

{% block body %}
    <section class="border-b border-line">
        <div class="container-page py-12">
            <p class="eyebrow mb-3">Formation</p>
            <h1 class="text-3xl font-bold tracking-tight text-fg mb-4 max-w-[24ch]">{{ formation.title }}</h1>

            {# Métadonnées : difficulté, durée, tags #}
            <div class="flex flex-wrap items-center gap-2 mb-6">
                {% if formation.difficulty %}
                    <span class="badge badge--accent">{{ formation.difficulty.label }}</span>
                {% endif %}
                {% if formation.estimatedMinutes %}
                    <span class="badge">~{{ formation.estimatedMinutes }} min</span>
                {% endif %}
                {% for tag in formation.tags %}
                    <span class="tag">{{ tag.label }}</span>
                {% endfor %}
            </div>

            {# Appel à l'action principal (haut de page). #}
            <div class="mb-8">
                {{ include('formation/_enroll_control.html.twig') }}
            </div>

            {# Description : HTML déjà rendu par la sync (CommonMark emballe dans <p>), d'où le <div> + raw. #}
            <div class="prose-chapter text-md text-fg-secondary max-w-[60ch] mb-8">{{ formation.description|raw }}</div>

            {# Prérequis et objectifs : blocs HTML déjà rendus par la sync (cf. ReadmeParser). #}
            {% if formation.prerequisites %}
                <div class="callout max-w-[60ch] mb-6">
                    <p class="font-semibold text-fg mb-1">Prérequis</p>
                    <div class="prose-chapter text-sm text-fg-secondary">{{ formation.prerequisites|raw }}</div>
                </div>
            {% endif %}

            {% if formation.objectives %}
                <div class="max-w-[60ch]">
                    <h2 class="text-lg font-bold tracking-tight text-fg mb-2">Ce que tu sauras faire à la fin</h2>
                    <div class="prose-chapter text-md text-fg-secondary">{{ formation.objectives|raw }}</div>
                </div>
            {% endif %}
        </div>
    </section>

    <section>
        <div class="container-page py-10">
            <h2 class="text-xl font-bold tracking-tight text-fg mb-5">Plan des chapitres</h2>

            {% if formation.chapters is empty %}
                <div class="callout">Aucun chapitre pour le moment.</div>
            {% else %}
                <ol class="grid gap-3">
                    {% for chapter in formation.chapters %}
                        {% set isDone = chapter.id in completedChapterIds %}
                        <li>
                            <a href="{{ path('app_formation_chapter', { slug: formation.slug, chapterSlug: chapter.slug }) }}" class="card card--interactive flex items-center gap-4 no-underline{% if isDone %} border-accent{% endif %}">
                                {% if isDone %}
                                    <span class="text-success text-lg leading-none" aria-hidden="true" title="Terminé">&checkmark;</span>
                                {% else %}
                                    <span class="font-mono text-sm text-muted">{{ '%02d'|format(chapter.position) }}</span>
                                {% endif %}
                                <span class="text-md font-medium {{ isDone ? 'text-fg-secondary' : 'text-fg' }}">{{ chapter.title }}</span>
                                {% if isDone %}
                                    <span class="badge badge--success ml-auto">Terminé</span>
                                {% else %}
                                    <span class="ml-auto text-muted" aria-hidden="true">&rarr;</span>
                                {% endif %}
                            </a>
                        </li>
                    {% endfor %}
                </ol>
            {% endif %}

            {# Projet fil rouge : bloc HTML déjà rendu par la sync (cf. ReadmeParser). #}
            {% if formation.project %}
                <div class="mt-10">
                    <h2 class="text-xl font-bold tracking-tight text-fg mb-3">Projet fil rouge</h2>
                    <div class="prose-chapter text-md text-fg-secondary max-w-[60ch]">{{ formation.project|raw }}</div>
                </div>
            {% endif %}

            {# Appel à l'action répété (bas de page). #}
            <div class="mt-10 pt-6 border-t border-line">
                {{ include('formation/_enroll_control.html.twig') }}
            </div>
        </div>
    </section>
{% endblock %}
